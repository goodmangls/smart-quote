<!DOCTYPE html>
<html lang="en">
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Secure sign-in to Smart Quote</title>
  </head>
  <body style="margin:0; padding:0; background:#f3f6fb; color:#111827; font-family:-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;">
    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="background:#f3f6fb; margin:0; padding:32px 16px;">
      <tr>
        <td align="center">
          <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="max-width:640px; background:#ffffff; border-radius:22px; overflow:hidden; border:1px solid #e5eaf3; box-shadow:0 18px 48px rgba(15,23,42,0.10);">
            <tr>
              <td style="background:linear-gradient(135deg,#0f172a 0%,#1e3a8a 48%,#2563eb 100%); padding:32px 36px; color:#ffffff;">
                <div style="font-size:12px; letter-spacing:0.18em; text-transform:uppercase; color:#bfdbfe; font-weight:700; margin-bottom:12px;">BridgeLogis Smart Quote</div>
                <h1 style="font-size:28px; line-height:1.25; margin:0; font-weight:800;">Your secure sign-in link is ready</h1>
                <p style="font-size:15px; line-height:1.7; color:#dbeafe; margin:14px 0 0;">Use the button below to access your quotation workspace. No password is required.</p>
              </td>
            </tr>
            <tr>
              <td style="padding:36px;">
                <p style="font-size:16px; line-height:1.7; margin:0 0 18px; color:#1f2937;">Hi<%= " #{@user.name}" if @user.name.present? %>,</p>
                <p style="font-size:16px; line-height:1.7; margin:0 0 26px; color:#374151;">We received a request to sign in to <strong style="color:#111827;">BridgeLogis Smart Quote</strong>. For your security, this link expires in <strong><%= @expires_in_minutes %> minutes</strong> and can only be used once.</p>
                <table role="presentation" cellspacing="0" cellpadding="0" border="0" style="margin:0 0 30px;">
                  <tr>
                    <td align="center" style="border-radius:12px; background:#2563eb; box-shadow:0 10px 22px rgba(37,99,235,0.28);">
                      <a href="<%= @magic_link_url %>" style="display:inline-block; padding:15px 28px; color:#ffffff; font-size:16px; font-weight:700; text-decoration:none; border-radius:12px;">Sign in securely</a>
                    </td>
                  </tr>
                </table>
                <div style="background:#f8fafc; border:1px solid #e2e8f0; border-radius:16px; padding:18px 20px; margin:0 0 26px;">
                  <p style="font-size:13px; line-height:1.6; margin:0 0 8px; color:#64748b; font-weight:700; text-transform:uppercase; letter-spacing:0.08em;">Security note</p>
                  <p style="font-size:14px; line-height:1.7; margin:0; color:#475569;">If you did not request this email, you can safely ignore it. BridgeLogis will never ask you to forward this link or share verification details.</p>
                </div>
                <p style="font-size:13px; line-height:1.6; margin:0 0 8px; color:#64748b;">If the button does not work, copy and paste this URL into your browser:</p>
                <p style="font-size:13px; line-height:1.6; margin:0; color:#475569; word-break:break-all;"><%= @magic_link_url %></p>
              </td>
            </tr>
            <tr>
              <td style="background:#f8fafc; border-top:1px solid #e5eaf3; padding:24px 36px;">
                <p style="font-size:13px; line-height:1.6; margin:0; color:#64748b;"><strong style="color:#334155;">Goodman GLS</strong> · BridgeLogis Smart Quote</p>
                <p style="font-size:12px; line-height:1.6; margin:8px 0 0; color:#94a3b8;">A secure quotation workspace for global logistics operations.</p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
